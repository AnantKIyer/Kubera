# Copy to .env.local and fill in your Convex deployment values.
# Run `npx convex dev` once to generate these automatically.

CONVEX_DEPLOYMENT=dev:your-deployment-name
NEXT_PUBLIC_CONVEX_URL=https://your-deployment-name.convex.cloud
NEXT_PUBLIC_CONVEX_SITE_URL=https://your-deployment-name.convex.site

# Field encryption (set in Convex, not .env.local):
#   node scripts/generate-encryption-key.mjs
#   npx convex env set DATA_ENCRYPTION_KEY "<generated-key>"
#   npm run test:encryption   # local smoke test (no Convex required)
# See README "Optional: field encryption" for rotation and fallback behavior.
